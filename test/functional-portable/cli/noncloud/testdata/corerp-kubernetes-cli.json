{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "languageVersion": "2.0",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "6050584823325268153"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "global",
      "metadata": {
        "description": "Specifies the location for resources."
      }
    },
    "environment": {
      "type": "string",
      "metadata": {
        "description": "Specifies the environment for resources."
      }
    },
    "magpieimage": {
      "type": "string",
      "metadata": {
        "description": "Specifies the image to be deployed."
      }
    }
  },
  "imports": {
    "radius": {
      "provider": "Radius",
      "version": "latest"
    }
  },
  "resources": {
    "app": {
      "import": "radius",
      "type": "Radius.Core/applications@2025-08-01-preview",
      "properties": {
        "name": "kubernetes-cli-json",
        "location": "[parameters('location')]",
        "properties": {
          "environment": "[parameters('environment')]"
        }
      }
    },
    "containera": {
      "import": "radius",
      "type": "Radius.Compute/containers@2025-08-01-preview",
      "properties": {
        "name": "containera-json",
        "location": "[parameters('location')]",
        "properties": {
          "application": "[reference('app').id]",
          "environment": "[parameters('environment')]",
          "containers": {
            "main": {
              "image": "[parameters('magpieimage')]"
            }
          }
        }
      },
      "dependsOn": ["app"]
    },
    "containerb": {
      "import": "radius",
      "type": "Radius.Compute/containers@2025-08-01-preview",
      "properties": {
        "name": "containerb-json",
        "location": "[parameters('location')]",
        "properties": {
          "application": "[reference('app').id]",
          "environment": "[parameters('environment')]",
          "containers": {
            "main": {
              "image": "[parameters('magpieimage')]"
            }
          }
        }
      },
      "dependsOn": ["app"]
    }
  }
}
