{
  "name": "@radius-project/typespec-bicep-types",
  "version": "0.1.0",
  "private": true,
  "description": "TypeSpec emitter that generates Bicep extensibility types (types.json, types.md, docs) directly from TypeSpec, replacing the deprecated @autorest/bicep AutoRest extension.",
  "type": "module",
  "main": "dist/src/index.js",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src",
    "src"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -p . --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p . --noEmit",
    "compile-projects": "node dist/src/cmd/compile-projects.js",
    "rebuild-index": "node dist/src/cmd/rebuild-index.js",
    "clean": "rimraf dist"
  },
  "author": "The Radius Authors",
  "license": "Apache-2.0",
  "dependencies": {
    "bicep-types": "0.6.49-g556bf5edad"
  },
  "peerDependencies": {
    "@azure-tools/typespec-azure-resource-manager": "^0.69.0",
    "@typespec/compiler": "^1.14.0",
    "@typespec/http": "^1.14.0",
    "@typespec/openapi": "^1.14.0",
    "@typespec/versioning": "^0.84.0"
  },
  "devDependencies": {
    "@azure-tools/typespec-azure-resource-manager": "^0.70.0",
    "@types/node": "^26.1.1",
    "@typespec/compiler": "^1.14.0",
    "@typespec/http": "^1.14.0",
    "@typespec/openapi": "^1.14.0",
    "@typespec/versioning": "^0.84.0",
    "rimraf": "^6.1.3",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
