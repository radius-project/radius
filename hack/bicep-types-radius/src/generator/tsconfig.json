{
  "compilerOptions": {
    "skipLibCheck": true,
    "module": "node16",
    "moduleResolution": "node16",
    "noEmitOnError": true,
    "noImplicitReturns": true,
    "sourceMap": true,
    "declarationMap": true,
    "strict": true,
    "declaration": true,
    "stripInternal": true,
    "noEmitHelpers": false,
    "target": "es2022",
    "types": ["node"],
    "esModuleInterop": true,
    "lib": ["es2022"],
    "newLine": "LF",
    "outDir": "dist",
    "rootDir": ".",
    "forceConsistentCasingInFileNames": true
  },
  "exclude": ["dist", "node_modules"]
}
